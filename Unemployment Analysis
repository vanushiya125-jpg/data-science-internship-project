# ------------------------------------------------------------
# IMPORT LIBRARIES
# ------------------------------------------------------------
import pandas as pd
import numpy as np
import matplotlib.pyplot as plt

# ------------------------------------------------------------
# LOAD DATASET
# ------------------------------------------------------------
print("Loading dataset...")

# Replace with your dataset file name
df = pd.read_csv("unemployment.csv")

print("Dataset loaded successfully")

# ------------------------------------------------------------
# DISPLAY DATA
# ------------------------------------------------------------
print("First 5 rows of dataset:")
print(df.head())

print("\nLast 5 rows:")
print(df.tail())

# ------------------------------------------------------------
# DATA INFORMATION
# ------------------------------------------------------------
print("\nDataset Information:")
print(df.info())

print("\nStatistical Summary:")
print(df.describe())

# ------------------------------------------------------------
# CHECK MISSING VALUES
# ------------------------------------------------------------
print("\nChecking for missing values:")
print(df.isnull().sum())

# Fill missing values if any
df = df.fillna(method='ffill')

# ------------------------------------------------------------
# DATA CLEANING
# ------------------------------------------------------------
print("\nCleaning data...")

# Convert Date column if exists
if 'Date' in df.columns:
    df['Date'] = pd.to_datetime(df['Date'])

print("Data cleaning completed")

# ------------------------------------------------------------
# SORT DATA
# ------------------------------------------------------------
if 'Date' in df.columns:
    df = df.sort_values(by='Date')

# ------------------------------------------------------------
# VISUALIZATION SECTION
# ------------------------------------------------------------

# Line Plot (Trend Over Time)
if 'Date' in df.columns:
    plt.figure()
    plt.plot(df['Date'], df['Unemployment Rate'])
    plt.title("Unemployment Rate Over Time")
    plt.xlabel("Date")
    plt.ylabel("Rate")
    plt.xticks(rotation=45)
    plt.show()

# Histogram
plt.figure()
plt.hist(df['Unemployment Rate'])
plt.title("Distribution of Unemployment Rate")
plt.xlabel("Rate")
plt.ylabel("Frequency")
plt.show()

# Box Plot
plt.figure()
plt.boxplot(df['Unemployment Rate'])
plt.title("Boxplot of Unemployment Rate")
plt.show()

# ------------------------------------------------------------
# GROUP ANALYSIS (if region exists)
# ------------------------------------------------------------
if 'Region' in df.columns:
    region_data = df.groupby('Region')['Unemployment Rate'].mean()
    print("\nAverage Unemployment by Region:")
    print(region_data)

    region_data.plot(kind='bar')
    plt.title("Region-wise Unemployment")
    plt.show()

# ------------------------------------------------------------
# COVID IMPACT ANALYSIS
# ------------------------------------------------------------
print("\nAnalyzing COVID-19 impact...")

if 'Date' in df.columns:
    covid_data = df[df['Date'] >= '2020-01-01']

    plt.figure()
    plt.plot(covid_data['Date'], covid_data['Unemployment Rate'])
    plt.title("Unemployment During COVID-19")
    plt.xticks(rotation=45)
    plt.show()

# ------------------------------------------------------------
# TREND ANALYSIS
# ------------------------------------------------------------
print("\nTrend Analysis:")

avg_rate = df['Unemployment Rate'].mean()
max_rate = df['Unemployment Rate'].max()
min_rate = df['Unemployment Rate'].min()

print("Average Rate:", avg_rate)
print("Maximum Rate:", max_rate)
print("Minimum Rate:", min_rate)

# ------------------------------------------------------------
# INSIGHTS GENERATION
# ------------------------------------------------------------
print("\nInsights:")

if max_rate > avg_rate:
    print("- There are spikes in unemployment rates")

if min_rate < avg_rate:
    print("- Some periods show economic recovery")

print("- External factors like pandemic affect employment")

# ------------------------------------------------------------
# SIMPLE PREDICTION (OPTIONAL TREND LINE)
# ------------------------------------------------------------
print("\nAdding trend line...")

x = np.arange(len(df))
y = df['Unemployment Rate']

coeff = np.polyfit(x, y, 1)
trend = np.poly1d(coeff)

plt.figure()
plt.plot(df['Unemployment Rate'], label='Original')
plt.plot(trend(x), label='Trend Line')
plt.legend()
plt.title("Trend Line Analysis")
plt.show()

# ------------------------------------------------------------
# CONCLUSION
# ------------------------------------------------------------
print("\nConclusion:")
print("Unemployment trends show variation over time.")
print("COVID period had significant impact.")
print("Data visualization helps understand patterns clearly.")

